local flinging = false
local flingBambam = nil
local flingDied = nil
local noclipConnection = nil
local savedLocation = nil

local function tweenTo(targetCFrame, duration)
	local char = LocalPlayer.Character
	local root = getRoot(char)
	local humanoid = char and char:FindFirstChildOfClass("Humanoid")
	if not root or not humanoid then return end

	if humanoid.SeatPart or humanoid.Sit then
		humanoid.Sit = false
		task.wait(0.05)
	end

	local tween = TweenService:Create(root, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
		CFrame = targetCFrame
	})
	tween:Play()
	tween.Completed:Wait()
end

local function startNoclip()
	noclipConnection = RunService.Stepped:Connect(function()
		local char = LocalPlayer.Character
		if char then
			for _, child in pairs(char:GetDescendants()) do
				if child:IsA("BasePart") and child.CanCollide then
					child.CanCollide = false
				end
			end
		end
	end)
end

local function stopNoclip()
	if noclipConnection then
		noclipConnection:Disconnect()
		noclipConnection = nil
	end
end

local function stopFling()
	flinging = false
	stopNoclip()

	if flingDied then flingDied:Disconnect() flingDied = nil end

	if flingBambam and flingBambam.Parent then
		flingBambam:Destroy()
		flingBambam = nil
	end

	local char = LocalPlayer.Character
	if char then
		for _, child in pairs(char:GetDescendants()) do
			if child:IsA("BasePart") then
				child.CustomPhysicalProperties = PhysicalProperties.new(0.7, 0.3, 0.5)
				child.Massless = false
			end
		end
	end
end

local function startFling()
	local char = LocalPlayer.Character
	if not char then return end

	for _, child in pairs(char:GetDescendants()) do
		if child:IsA("BasePart") then
			child.CustomPhysicalProperties = PhysicalProperties.new(100, 0.3, 0.5)
		end
	end

	startNoclip()
	task.wait(0.1)

	local root = getRoot(char)
	if not root then return end

	flingBambam = Instance.new("BodyAngularVelocity")
	flingBambam.Name = "FlingBAV"
	flingBambam.Parent = root
	flingBambam.AngularVelocity = Vector3.new(0, 99999, 0)
	flingBambam.MaxTorque = Vector3.new(0, math.huge, 0)
	flingBambam.P = math.huge

	for _, v in pairs(char:GetChildren()) do
		if v:IsA("BasePart") then
			v.CanCollide = false
			v.Massless = true
			v.Velocity = Vector3.new(0, 0, 0)
		end
	end

	flinging = true

	local humanoid = char:FindFirstChildOfClass("Humanoid")
	if humanoid then
		flingDied = humanoid.Died:Connect(stopFling)
	end

	task.spawn(function()
		repeat
			if flingBambam and flingBambam.Parent then
				flingBambam.AngularVelocity = Vector3.new(0, 99999, 0)
			end
			task.wait(0.2)
			if flingBambam and flingBambam.Parent then
				flingBambam.AngularVelocity = Vector3.new(0, 0, 0)
			end
			task.wait(0.1)
		until not flinging
	end)
end

kill.MouseButton1Click:Connect(function()
	local uname = username.Value
	if uname == "" then return end

	local target = Players:FindFirstChild(uname)
	if not target or not target.Character then return end

	local targetRoot = getRoot(target.Character)
	local myChar = LocalPlayer.Character
	local myRoot = getRoot(myChar)
	if not targetRoot or not myRoot then return end

	savedLocation = myRoot.CFrame

	local initialPos = targetRoot.CFrame * CFrame.new(0, 3, 0)
	tweenTo(initialPos, 0.1)
	startFling()

	local flingTime = 3
	local startTime = tick()

	task.spawn(function()
		while flinging and (tick() - startTime) < flingTime do
			if targetRoot and targetRoot.Parent then
				local currentTargetPos = targetRoot.CFrame * CFrame.new(0, 3, 0)
				tweenTo(currentTargetPos, 0.1)
			end
			task.wait()
		end

		if myRoot and myRoot.Parent then
			tweenTo(savedLocation, 0.1)
		end

		stopFling()
		savedLocation = nil
	end)
end)

