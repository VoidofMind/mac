end

local function cloneAndMirrorCharacter(character, parent)
	task.wait(2)
	character.Archivable = true
	local ok, clone = pcall(function() return character:Clone() end)
	if not ok or not clone then return nil, {} end

	clone.Parent = parent

	local chum = clone:FindFirstChildOfClass("Humanoid")
	if chum then chum.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None end

	local cloneAnimator = clone:FindFirstChild("Animator", true)
	if cloneAnimator then
		for _, track in ipairs(cloneAnimator:GetPlayingAnimationTracks()) do track:Stop() end
	end

	local connections = {}

	local realAnimator = character:FindFirstChild("Animator", true)
	if realAnimator and cloneAnimator then
		local conn = realAnimator.AnimationPlayed:Connect(function(animTrack)
			local load = cloneAnimator:LoadAnimation(animTrack.Animation)
			load:Play()
			load:AdjustSpeed(animTrack.Speed)
			animTrack.Stopped:Connect(function() load:Stop() load:Destroy() end)
		end)
		table.insert(connections, conn)
	end

	local moveConn = RunService.RenderStepped:Connect(function()
		if character and clone and character.PrimaryPart and clone.PrimaryPart then
			clone:SetPrimaryPartCFrame(character:GetPrimaryPartCFrame())
		end
	end)
	table.insert(connections, moveConn)

	local destroyConn = character.Destroying:Connect(function()
		if clone and clone.Parent then clone:Destroy() end
	end)
	table.insert(connections, destroyConn)

	return clone, connections
end

local function isCharacterDescendant(instance)
	for _, player in ipairs(Players:GetPlayers()) do
		if player.Character and instance:IsDescendantOf(player.Character) then return true end
	end
	return false
end

local function setupOtherPlayer(player, targetPlayer)
	if player == targetPlayer or player == Players.LocalPlayer then return end
	local character = player.Character
	if not character then return end

	task.spawn(function()
		local clone, connections = cloneAndMirrorCharacter(character, worldModel)
		if not clone then return end
		otherClones[clone] = { connections = connections }

		player.CharacterAdded:Connect(function(newChar)
			if clone and clone.Parent then clone:Destroy() end
			for _, c in ipairs(connections) do c:Disconnect() end
			otherClones[clone] = nil

			task.spawn(function()
				local newClone, newConns = cloneAndMirrorCharacter(newChar, worldModel)
				if newClone then otherClones[newClone] = { connections = newConns } end
			end)
		end)
	end)
end

local function setupAllOtherPlayers(targetPlayer)
	clearOtherClones()
	for _, player in ipairs(Players:GetPlayers()) do
		setupOtherPlayer(player, targetPlayer)
	end
end

local function cloneMap()
	for source, clone in pairs(mapClones) do
		if source and source.Parent and clone and clone.Parent then
			clone.CFrame = source.CFrame
		else
			if clone and clone.Parent then clone:Destroy() end
			mapClones[source] = nil
		end
	end

	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("BasePart") and obj ~= workspace.Terrain
			and not isCharacterDescendant(obj) and not mapClones[obj] then
			local ok, clone = pcall(function() return obj:Clone() end)
			if ok and clone then
				clone.Anchored = true
				clone.Parent = worldModel
				mapClones[obj] = clone
				obj.Destroying:Connect(function()
					if clone and clone.Parent then clone:Destroy() end
					mapClones[obj] = nil
				end)
			end
		end
	end
end

local function startMapUpdates()
	clearMap()
	cloneMap()

	mapConnection = workspace.DescendantAdded:Connect(function(obj)
		if obj:IsA("BasePart") and obj ~= workspace.Terrain
			and not isCharacterDescendant(obj) and not mapClones[obj] then
			task.wait(0.1)
			local ok, clone = pcall(function() return obj:Clone() end)
			if ok and clone then
				clone.Anchored = true
				clone.Parent = worldModel
				mapClones[obj] = clone
				obj.Destroying:Connect(function()
					if clone and clone.Parent then clone:Destroy() end
					mapClones[obj] = nil
				end)
			end
		end
	end)
end

local function setupCharacter(character, targetPlayer)
	clearCharConnections()
	if clonedCharacter then clonedCharacter:Destroy() clonedCharacter = nil end

	task.spawn(function()
		task.wait(2)
		character.Archivable = true
		local ok, clone = pcall(function() return character:Clone() end)
		if not ok or not clone then return end

		clone.Parent = worldModel
		clonedCharacter = clone

		local chum = clone:FindFirstChildOfClass("Humanoid")
		if chum then chum.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None end

		local cloneAnimator = clone:FindFirstChild("Animator", true)
		if cloneAnimator then
			for _, track in ipairs(cloneAnimator:GetPlayingAnimationTracks()) do track:Stop() end
		end

		local realAnimator = character:FindFirstChild("Animator", true)
		if realAnimator and cloneAnimator then
			local conn = realAnimator.AnimationPlayed:Connect(function(animTrack)
				local load = cloneAnimator:LoadAnimation(animTrack.Animation)
				load:Play()
				load:AdjustSpeed(animTrack.Speed)
				animTrack.Stopped:Connect(function() load:Stop() load:Destroy() end)
			end)
			table.insert(charConnections, conn)
		end

		local moveConn = RunService.RenderStepped:Connect(function()
			if character and clone and character.PrimaryPart and clone.PrimaryPart then
				clone:SetPrimaryPartCFrame(character:GetPrimaryPartCFrame())
			end
		end)
		table.insert(charConnections, moveConn)

		local destroyConn = character.Destroying:Connect(function()
			if clonedCharacter then clonedCharacter:Destroy() clonedCharacter = nil end
		end)
		table.insert(charConnections, destroyConn)
	end)
end

local mapTimer = 0

local function startSpectating(uname)
	stopSpectating()
	if uname == "" then return end

	local target = Players:FindFirstChild(uname)
	if not target then return end

	local character = target.Character or target.CharacterAdded:Wait()

	startMapUpdates()
	setupCharacter(character, target)
	setupAllOtherPlayers(target)

	target.CharacterAdded:Connect(function(newChar)
		setupCharacter(newChar, target)
	end)

	Players.PlayerAdded:Connect(function(player)
		setupOtherPlayer(player, target)
	end)

	renderConnection = RunService.RenderStepped:Connect(function(dt)
		mapTimer = mapTimer + dt
		if mapTimer >= MAP_UPDATE_INTERVAL then
			mapTimer = 0
			for source, clone in pairs(mapClones) do
				if source and source.Parent and clone and clone.Parent then
					clone.CFrame = source.CFrame
				end
			end
		end

		local head = clonedCharacter and clonedCharacter:FindFirstChild("Head")
		if not head then return end

		orbitAngle = orbitAngle + ORBIT_SPEED * dt
		local headPos = head.Position
		local camPos = headPos + Vector3.new(
			math.sin(orbitAngle) * ORBIT_DISTANCE,
			ORBIT_HEIGHT,
			math.cos(orbitAngle) * ORBIT_DISTANCE
		)
		vpCamera.CFrame = CFrame.lookAt(camPos, headPos)
	end)
end

username.Changed:Connect(function(newValue)
	startSpectating(newValue)
end)

if username.Value ~= "" then
	startSpectating(username.Value)
end

local TWEEN_DURATION = 0.4
local EASING_STYLE = Enum.EasingStyle.Quad

local isFolded = false
local isHidden = false

local originalWindowState = {
	Size = window.Size,
	Position = window.Position,
}

local originalChildrenState = {}

local function storeChildrenState()
	originalChildrenState = {}
	for _, child in ipairs(window:GetDescendants()) do
		if child:IsA("GuiObject") and child ~= window then
			originalChildrenState[child] = {
				Size = child.Size,
				Position = child.Position,
				BackgroundTransparency = child.BackgroundTransparency,
				TextTransparency = (child:IsA("TextLabel") or child:IsA("TextButton") or child:IsA("TextBox"))
					and child.TextTransparency or nil,
			}
		end
	end
end

storeChildrenState()

for _, obj in ipairs(window:GetDescendants()) do
	if obj:IsA("GuiObject") and obj ~= window then
		if obj.BackgroundTransparency ~= nil then obj.BackgroundTransparency = 1 end
		if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
			obj.TextTransparency = 1
		end
	end
end

task.wait()

for obj, state in pairs(originalChildrenState) do
	if obj and obj.Parent then
		TweenService:Create(obj, TweenInfo.new(0.5, EASING_STYLE), {
			BackgroundTransparency = state.BackgroundTransparency,
			TextTransparency = state.TextTransparency,
		}):Play()
	end
end

local function foldWindow()
	if isHidden or isFolded then return end
	isFolded = true

	for obj, state in pairs(originalChildrenState) do
		if obj and obj.Parent then
			local props = { BackgroundTransparency = 1 }
			if state.TextTransparency ~= nil then props.TextTransparency = 1 end
			TweenService:Create(obj, TweenInfo.new(TWEEN_DURATION, EASING_STYLE), props):Play()
		end
	end

	TweenService:Create(window, TweenInfo.new(TWEEN_DURATION, EASING_STYLE), {
		Size = UDim2.new(originalWindowState.Size.X.Scale, originalWindowState.Size.X.Offset, 0, topbar.AbsoluteSize.Y),
	}):Play()
end

local function unfoldWindow()
	if not isFolded then return end
	isFolded = false

	for obj, state in pairs(originalChildrenState) do
		if obj and obj.Parent then
			local props = { BackgroundTransparency = state.BackgroundTransparency }
			if state.TextTransparency ~= nil then props.TextTransparency = state.TextTransparency end
			TweenService:Create(obj, TweenInfo.new(TWEEN_DURATION, EASING_STYLE), props):Play()
		end
	end

	TweenService:Create(window, TweenInfo.new(TWEEN_DURATION, EASING_STYLE), {
		Size = originalWindowState.Size,
	}):Play()
end

fold.MouseButton1Click:Connect(function()
	if isFolded then unfoldWindow() else foldWindow() end
end)

local function squishAll(targetSize, targetPos)
	for obj, state in pairs(originalChildrenState) do
		if obj and obj.Parent then
			local props = { Size = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 1 }
			if state.TextTransparency ~= nil then props.TextTransparency = 1 end
			TweenService:Create(obj, TweenInfo.new(TWEEN_DURATION, EASING_STYLE), props):Play()
		end
	end
	TweenService:Create(window, TweenInfo.new(TWEEN_DURATION, EASING_STYLE), {
		Size = targetSize,
		Position = targetPos,
	}):Play()
end

local function restoreAll()
	for obj, state in pairs(originalChildrenState) do
		if obj and obj.Parent then
			local props = {
				Size = state.Size,
				Position = state.Position,
				BackgroundTransparency = state.BackgroundTransparency,
			}
			if state.TextTransparency ~= nil then props.TextTransparency = state.TextTransparency end
			TweenService:Create(obj, TweenInfo.new(TWEEN_DURATION, EASING_STYLE), props):Play()
		end
	end
end

local function hideWindow()
	if isHidden or isFolded then return end
	isHidden = true
	storeChildrenState()

	local iconAbs = icon.AbsolutePosition
	local iconSize = icon.AbsoluteSize
	window.AnchorPoint = Vector2.new(0.5, 0.5)

	squishAll(
		UDim2.new(0, 40, 0, 40),
		UDim2.new(0, iconAbs.X + iconSize.X / 2, 0, iconAbs.Y + iconSize.Y / 2)
	)

	task.delay(TWEEN_DURATION, function()
		window.Visible = false
		icon.Visible = true
	end)
end

local function unhideWindow()
	if not isHidden then return end
	isHidden = false

	window.Visible = true
	icon.Visible = false
	restoreAll()

	TweenService:Create(window, TweenInfo.new(TWEEN_DURATION, EASING_STYLE), {
		Size = originalWindowState.Size,
		Position = originalWindowState.Position,
	}):Play()

	task.delay(TWEEN_DURATION, function()
		window.AnchorPoint = Vector2.new(0, 0)
	end)
end

hide.MouseButton1Click:Connect(function()
	if isHidden then unhideWindow() else hideWindow() end
end)

